# 360dialog / WhatsApp
WHATSAPP_API_KEY=
WEBHOOK_VERIFY_TOKEN=sinan2024
# Token directo de Meta (Cloud API) — la descarga de imágenes/media va 100%
# por graph.facebook.com con este token, 360dialog no participa en esa ruta
# (la URL de binario que devolvía quedaba ligada a su propio App ID ante Meta).
META_TOKEN=

# Postgres — Railway lo inyecta automáticamente al añadir el addon, no lo seteen manualmente en Railway
DATABASE_URL=postgres://user:pass@host:port/db

# Claude / Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Google Drive — OAuth de una cuenta personal de Gmail (no service account: las
# service accounts no tienen cuota de almacenamiento propia y sin Google
# Workspace no hay Unidades Compartidas donde dársela). GOOGLE_REFRESH_TOKEN se
# obtiene una vez con el flujo OAuth (ver README/histórico de setup).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID_BOLETAS=
GOOGLE_DRIVE_FOLDER_ID_BACKUPS=
GOOGLE_DRIVE_FOLDER_ID_REPORTES=

# Backups y resumen diario (formato cron estándar)
BACKUP_CRON_SCHEDULE=0 6 * * *
BACKUP_TIMEZONE=America/Santiago
RESUMEN_DIARIO_CRON_SCHEDULE=0 8 * * *

PORT=3000
